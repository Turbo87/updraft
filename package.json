{
	"name": "updraft",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.10.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "pnpm --filter @updraft/frontend dev",
		"build": "pnpm --filter @updraft/frontend build",
		"check": "pnpm -r check",
		"test": "pnpm -r test",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1"
	}
}
