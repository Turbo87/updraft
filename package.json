{
  "name": "updraft",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @updraft/frontend dev",
    "storybook": "pnpm --filter @updraft/frontend storybook",
    "build": "pnpm --filter @updraft/frontend build",
    "build:storybook": "pnpm --filter @updraft/frontend build-storybook",
    "check": "pnpm -r check",
    "test": "pnpm -r --filter='!@updraft/e2e' test",
    "test:e2e": "pnpm --filter @updraft/e2e test",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@tauri-apps/cli": "2.11.4",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prefer-let": "4.2.2",
    "eslint-plugin-svelte": "3.21.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-svelte": "4.1.1",
    "svelte": "5.56.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  }
}
