{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Updraft",
  "identifier": "aero.updraft",
  "build": {
    "frontendDist": "../frontend/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @updraft/frontend dev",
    "beforeBuildCommand": "pnpm --filter @updraft/frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "Updraft",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
